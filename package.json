{
    "name": "agel-dashboard-monorepo",
    "version": "2.0.0",
    "private": true,
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && .\\venv\\Scripts\\uvicorn main:app --reload --port 3121",
